#!/bin/bash
#
# Pre-commit hook that runs format-check + clippy before allowing a commit.
# These are the same gates CI enforces, surfaced early so drift is caught
# locally instead of after pushing.
#
# Tests are NOT run here — the MQDB suite takes ~10 minutes. CI will run
# them on push. If you want to run them locally, use `cargo make ci`.
#
# Activate this hook once per clone:
#   git config core.hooksPath .githooks

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit checks (format + clippy)...${NC}"
echo ""

if ! command -v cargo-make &> /dev/null; then
    echo -e "${RED}Error: cargo-make is not installed${NC}"
    echo "Install with: cargo install cargo-make"
    exit 1
fi

if ! cargo make format-check; then
    echo ""
    echo -e "${RED}✗ Formatting check failed${NC}"
    echo "Run \`cargo make format\` to auto-fix, then re-commit."
    exit 1
fi

if ! cargo make clippy; then
    echo ""
    echo -e "${RED}✗ Clippy failed${NC}"
    echo "Fix the warnings above and re-commit."
    echo "To bypass (strongly discouraged): git commit --no-verify"
    exit 1
fi

echo ""
echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
exit 0
